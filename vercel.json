{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "frontend": {
      "framework": "vite",
      "entrypoint": "frontend",
      "routePrefix": "/"
    },
    "backend": {
      "framework": "flask",
      "entrypoint": "backend",
      "routePrefix": "/_/backend",
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
