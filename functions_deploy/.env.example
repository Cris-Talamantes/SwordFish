FLASK_ENV=development
FLASK_DEBUG=true

# Comma-separated list of frontend origins allowed to call the API.
CORS_ORIGINS=http://localhost:5173

# Firebase Functions uses default credentials in production.
# For local-only testing, you may set SERVICE_ACCOUNT_PATH or SERVICE_ACCOUNT_JSON.
SERVICE_ACCOUNT_PATH=
SERVICE_ACCOUNT_JSON=

# Optional Firebase Storage bucket, usually: your-project-id.appspot.com
STORAGE_BUCKET=
