FLASK_ENV=development
FLASK_DEBUG=true
PORT=5000

# Comma-separated list of frontend origins allowed to call the API (include your Vercel URL).
CORS_ORIGINS=http://localhost:5173,https://your-project.vercel.app

# Firebase Admin credentials. Use ONE of these:
# 1. Path to a Firebase service account JSON file (filename relative to backend/ works):
GOOGLE_APPLICATION_CREDENTIALS=your-project-firebase-adminsdk-xxxxx.json

# 2. Raw service account JSON string:
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional Firebase Storage bucket, usually: your-project-id.appspot.com
FIREBASE_STORAGE_BUCKET=
